<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ScavgameTranslationUtils.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="ScavgameTranslationUtils.Views.TranslationWindow"
        x:DataType="vm:TranslationWindowViewModel"
        Closing="WindowClosing"
        Icon="/Assets/icon2.png"
        Title="Scavgame Translation Utils" >
  <TabControl SelectionChanged="AutosaveChanges">
    <TabItem Header="Metadata">
      <StackPanel>
        <Grid ColumnSpacing="10" RowSpacing="5" Margin="5">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition MinWidth="80" MaxWidth="600" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
            <RowDefinition MinHeight="80" MaxHeight="150" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0"
                     TextWrapping="Wrap"
                     Text="Translation progress" />
          <TextBlock Grid.Row="0" Grid.Column="1"
                     TextWrapping="Wrap"
                     Text="{Binding TranslationProgress, FallbackValue=0%, TargetNullValue=0%}" />
          <TextBlock Grid.Row="1" Grid.Column="0"
                     TextWrapping="Wrap"
                     Text="Translation name" />
          <TextBox Grid.Row="1" Grid.Column="1"
                   TextWrapping="Wrap"
                   Text="{Binding CurrentName}"
                   LostFocus="AutosaveChanges" />
          <TextBlock Grid.Row="2" Grid.Column="0"
                     TextWrapping="Wrap"
                     Text="Translation description" />
          <ScrollViewer Grid.Row="2" Grid.Column="1"
                        MaxHeight="150"
                        VerticalScrollBarVisibility="Visible">
            <TextBox TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Text="{Binding CurrentDescription}"
                     LostFocus="AutosaveChanges" />
          </ScrollViewer>
          <TextBlock Grid.Row="3" Grid.Column="0"
                     Text="Indent size" />
          <ComboBox Grid.Row="3" Grid.Column="1"
                    ItemsSource="{Binding AllowedIndents}"
                    SelectedItem="{Binding IndentSize}"
                    SelectionChanged="AutosaveChanges" />
          <TextBlock Grid.Row="4" Grid.Column="0"
                     TextWrapping="Wrap"
                     Text="Save changes automatically" />
          <CheckBox Grid.Row="4" Grid.Column="1"
                    IsChecked="{Binding AutosaveEnabled}" />
          <TextBlock Grid.Row="5" Grid.Column="0"
                     TextWrapping="Wrap"
                     Text="Sort keys in EN.json order" />
          <CheckBox Grid.Row="5" Grid.Column="1"
                    IsChecked="{Binding SortKeys}" />
        </Grid>
        <StackPanel Orientation="Horizontal" Margin="20" Spacing="10">
          <Button Click="SaveChangesManual"
                  Content="Save Changes" />
          <Button Click="CloseWindow"
                  Content="Save Changes and Close" />
          <Button Click="CloseWindowWithoutSaving"
                  Content="Close Without Saving" />
        </StackPanel>
      </StackPanel>
    </TabItem>
    <TabItem Header="Translation">
      <Grid ColumnSpacing="5" Margin="5">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition MinWidth="150" Width="*" />
          <ColumnDefinition Width="14" />
          <ColumnDefinition MinWidth="300" Width="4*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0" RowSpacing="4"
              ColumnDefinitions="*"
              RowDefinitions="Auto, Auto, Auto, Auto *">
          <Button Grid.Row="0" Grid.Column="0"
                  Command="{Binding ClearSearchCommand}"
                  Content="Clear search" />
          <TextBox Grid.Row="1" Grid.Column="0"
                   HorizontalAlignment="Stretch"
                   Text="{Binding KeySearchText, Delay=500}"
                   PlaceholderText="Search for key..." />
          <TextBox Grid.Row="2" Grid.Column="0"
                   HorizontalAlignment="Stretch"
                   Text="{Binding OriginalSearchText, Delay=500}"
                   PlaceholderText="Search text in EN.json..." />
          <TextBox Grid.Row="3" Grid.Column="0"
                   HorizontalAlignment="Stretch"
                   Text="{Binding TranslationSearchText, Delay=500}"
                   PlaceholderText="Search text in locale..." />
          <ListBox Grid.Row="4" Grid.Column="0"
                   IsVisible="{Binding ShouldDoSearch}"
                   Margin="5"
                   ItemsSource="{Binding SearchMatchingKeys}" SelectedItem="{Binding SelectedSearchListItem}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding FullPathDisplay}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <TreeView Grid.Row="4" Grid.Column="0"
                    IsVisible="{Binding !ShouldDoSearch}"
                    ItemsSource="{Binding NavData.TreeView}"
                    SelectedItem="{Binding SelectedTreeViewItem}">
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding SubNodes}">
                <TextBlock Text="{Binding PathPartView}" />
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
        <GridSplitter Grid.Row="0" Grid.Column="1"
                      Background="LightGray"
                      Width="2"
                      Margin="6" />
        <ScrollViewer Grid.Row="0" Grid.Column="2"
                      VerticalScrollBarVisibility="Visible">
          <StackPanel Orientation="Vertical"
                      Margin="0,0,40,0">
            <StackPanel Orientation="Horizontal" Spacing="5" Margin="5">
              <TextBlock VerticalAlignment="Center"
                         Text="Key" />
              <ComboBox VerticalAlignment="Center"
                        Name="MainKeysComboBox"
                        MinWidth="400"
                        SelectedIndex="{Binding CurrentKeyIndex}"
                        ItemsSource="{Binding NavData.ListView}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding FullPathView}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock VerticalAlignment="Center"
                         Text="Key view order" />
              <ComboBox VerticalAlignment="Center"
                        ItemsSource="{Binding DisplayKeySortOptions}"
                        SelectedItem="{Binding SelectedDisplayKeySorting}" />
              <TextBlock VerticalAlignment="Center"
                         Text="{Binding PaginationText, FallbackValue='Key 0 / Total 0', TargetNullValue='Key 0 / Total 0'}" />
            </StackPanel>
            <Grid HorizontalAlignment="Left">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button Grid.Row="0" Grid.Column="0"
                      Content="Previous"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Command="{Binding PreviousMainKeyCommand}" />
              <Button Grid.Row="0" Grid.Column="1"
                      Content="Next"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Command="{Binding NextMainKeyCommand}" />
              <Button Grid.Row="1" Grid.Column="0"
                      Content="Previous category"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Command="{Binding PreviousCategoryCommand}" />
              <Button Grid.Row="1" Grid.Column="1"
                      Content="Next category"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Command="{Binding NextCategoryCommand}" />
              <Button Grid.Row="0" Grid.Column="2"
                      Content="First untranslated"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Command="{Binding FirstUntranslatedKeyCommand}" />
              <Button Grid.Row="1" Grid.Column="2"
                      Content="Next untranslated"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Command="{Binding NextUntranslatedKeyCommand}" />
              <CheckBox Grid.Row="0" Grid.Column="3" 
                        Content="Render in-game text to the right (colors, etc.)"
                        IsChecked="{Binding RenderText}"
                        Margin="10, 0, 0, 0"/>
            </Grid>
            <Grid ColumnSpacing="10" RowSpacing="10" Margin="10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MaxWidth="140" />
                <ColumnDefinition Width="*" MaxWidth="700" />
                <ColumnDefinition Width="*" MaxWidth="700" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition MinHeight="60" Height="Auto" MaxHeight="350" />
                <RowDefinition MinHeight="60" Height="Auto" MaxHeight="350" />
                <RowDefinition MinHeight="60" Height="Auto" MaxHeight="350" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0"
                         Text="English"
                         TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="{Binding NonDisplayBoxesColumnSpan}"
                            MaxHeight="350"
                            VerticalScrollBarVisibility="Visible">
                <SelectableTextBlock Text="{Binding CurrentKeyEnglish}"
                                     FontSize="16"
                                     TextWrapping="Wrap"
                                     Margin="0, 0, 10, 0" />
              </ScrollViewer>
              <ScrollViewer Grid.Row="0" Grid.Column="2" IsVisible="{Binding RenderText}"
                            MaxHeight="350"
                            VerticalScrollBarVisibility="Visible">
                <TextBlock FontFamily="{StaticResource Unifont}"
                           FontSize="16"
                           Inlines="{Binding CurrentKeyEnglishDisplay}"
                           TextWrapping="Wrap"
                           Margin="0, 0, 10, 0" />
              </ScrollViewer>
              <TextBlock Grid.Row="1" Grid.Column="0"
                         Text="Translated"
                         TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="{Binding NonDisplayBoxesColumnSpan}"
                            MaxHeight="350"
                            VerticalScrollBarVisibility="Visible">
                <TextBox Text="{Binding CurrentKeyTranslation}"
                         FontSize="16"
                         LostFocus="AutosaveChanges"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Margin="0, 0, 10, 0" />
              </ScrollViewer>
              <ScrollViewer Grid.Row="1" Grid.Column="2" IsVisible="{Binding RenderText}"
                            MaxHeight="350"
                            VerticalScrollBarVisibility="Visible">
                <TextBlock FontFamily="{StaticResource Unifont}"
                           FontSize="16"
                           Inlines="{Binding CurrentKeyTranslationDisplay}"
                           TextWrapping="Wrap"
                           Margin="0, 0, 10, 0" />
              </ScrollViewer>
              <TextBlock Grid.Row="2" Grid.Column="0"
                         Text="Notes"
                         TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="2" Grid.Column="1"
                            MaxHeight="350"
                            VerticalScrollBarVisibility="Visible">
                <TextBlock Text="{Binding CurrentKeyNotes}"
                           TextWrapping="Wrap"
                           Margin="0, 0, 10, 0" />
              </ScrollViewer>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </TabItem>
  </TabControl>
</Window>